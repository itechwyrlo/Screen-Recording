<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0-android</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <RootNamespace>MauiScreenRecorder</RootNamespace>
    <UseMaui>true</UseMaui>
    <SingleProject>true</SingleProject>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ApplicationTitle>MauiScreenRecorder</ApplicationTitle>
    <ApplicationId>com.example.mauiscreenrecorder</ApplicationId>
    <SupportedOSPlatformVersion>21.0</SupportedOSPlatformVersion>
    <!-- SDK 10+ treats net8 Android workload as EOL; allow restore/build for this sample. -->
    <CheckEolWorkloads>false</CheckEolWorkloads>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Maui.Controls" Version="8.0.100" />
  </ItemGroup>

  <ItemGroup>
    <MauiXaml Include="App.xaml" />
    <MauiXaml Include="MainPage.xaml" />
  </ItemGroup>

</Project>